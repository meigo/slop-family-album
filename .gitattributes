# Normalize line endings across Mac and Windows.
# Text files: stored and checked out as LF on every platform.
* text=auto eol=lf

# Binary assets — never normalize.
*.icns binary
*.ico binary
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.webp binary
*.onnx binary
*.pdf binary
*.zip binary
*.db binary
*.sqlite binary

# Windows-only scripts must keep CRLF.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
